// Prisma schema file — defines the database models, connection, and client generator.
// Docs: https://pris.ly/d/prisma-schema

// Generates the Prisma Client into lib/generated/prisma so it can be imported
// throughout the codebase via ../lib/generated/prisma
generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"

}
// Connects to a PostgreSQL database using the DATABASE_URL environment variable.
// Requires the pgvector extension to be installed on the database instance.
datasource db {
  provider = "postgresql"
}

// Stores chunked document content with vector embeddings for similarity search.
// Each record represents a single chunk of a Slab/Markdown document.
model SlabContent {
  id               Int                         @id @default(autoincrement())
  title            String                      @db.VarChar(500)
  chunk_text       String
  // pgvector type — not natively supported by Prisma, so marked as Unsupported.
  // Embeddings are 768-dimensional vectors generated by gemini-embedding-001.
  embedding_vector Unsupported("vector(768)")?
  slab_url         String?                     @db.VarChar(1000)
  created_at       DateTime                    @default(now()) @db.Timestamptz

  // Maps to the existing slab_content table in the database
  @@map("slab_content")
}

// Tracks every question asked by Slack users for analytics and monthly reporting.
model QuestionAsked {
  id            Int      @id @default(autoincrement())
  user_id       String   @db.VarChar(255)
  question_text String
  timestamp     DateTime @default(now()) @db.Timestamptz

  // Indexes to speed up user-based and time-based lookups
  @@index([user_id])
  @@index([timestamp(sort: Desc)])
  // Maps to the existing questions_asked table in the database
  @@map("questions_asked")
}